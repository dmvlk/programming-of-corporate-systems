<Window x:Class="LibraryManagement.Views.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagement.Views"
        mc:Ignorable="d"
        Title="Управление жанрами" 
        Height="450" 
        Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="GenresDataGrid" 
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddButton" Content="Добавить" Width="100" Height="35" Margin="5" Click="AddButton_Click"/>
            <Button x:Name="EditButton" Content="Редактировать" Width="100" Height="35" Margin="5" Click="EditButton_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="100" Height="35" Margin="5" Click="DeleteButton_Click"/>
            <Button x:Name="CloseButton" Content="Закрыть" Width="100" Height="35" Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>