<Window x:Class="LibraryManagement.Views.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagement.ViewModels"
        mc:Ignorable="d"
        Title="Добавление книги" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <Label Grid.Row="0" Grid.Column="0" Content="Название:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleTextBox" Margin="5" Padding="3" Height="30"/>

        <!-- ISBN -->
        <Label Grid.Row="1" Grid.Column="0" Content="ISBN:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="ISBNTextBox" Margin="5" Padding="3" Height="30"/>

        <!-- Год публикации -->
        <Label Grid.Row="2" Grid.Column="0" Content="Год:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="YearTextBox" Margin="5" Padding="3" Height="30" Text="2024"/>

        <!-- Издатель -->
        <Label Grid.Row="3" Grid.Column="0" Content="Издатель:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="PublisherTextBox" Margin="5" Padding="3" Height="30"/>

        <!-- Количество -->
        <Label Grid.Row="4" Grid.Column="0" Content="В наличии:" Margin="5" VerticalAlignment="Center"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="QuantityTextBox" Margin="5" Padding="3" Height="30" Text="1"/>

        <!-- Автор -->
        <Label Grid.Row="5" Grid.Column="0" Content="Автор:" Margin="5" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <ComboBox x:Name="AuthorComboBox" 
                    Width="200" Height="30"
                    DisplayMemberPath="LastName"
                    SelectedValuePath="Id"/>
            <Button x:Name="AddAuthorButton" Content="+" Width="30" Height="30" Margin="5,0,0,0" 
                    Click="AddAuthorButton_Click" ToolTip="Добавить нового автора"/>
        </StackPanel>

        <!-- Жанр -->
        <Label Grid.Row="6" Grid.Column="0" Content="Жанр:" Margin="5" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <ComboBox x:Name="GenreComboBox" 
                    Width="200" Height="30"
                    DisplayMemberPath="Name"
                    SelectedValuePath="Id"/>
            <Button x:Name="AddGenreButton" Content="+" Width="30" Height="30" Margin="5,0,0,0" 
                    Click="AddGenreButton_Click" ToolTip="Добавить новый жанр"/>
        </StackPanel>

        <!-- Разделитель -->
        <Rectangle Grid.Row="7" Grid.ColumnSpan="2" Height="1" Fill="LightGray" Margin="0,10,0,10"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" Margin="0" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>