<Window x:Class="LibraryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagement.ViewModels"
        mc:Ignorable="d"
        Title="Управление библиотекой" 
        Height="600" 
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска и фильтрации -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" Margin="0,0,5,0" Padding="3"
                     ToolTip="Поиск по названию книги"/>

            <ComboBox ItemsSource="{Binding Authors}"
                      SelectedItem="{Binding SelectedAuthorFilter}"
                      DisplayMemberPath="LastName"
                      Width="150" Margin="5,0"
                      ToolTip="Фильтр по автору"/>

            <ComboBox ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenreFilter}"
                      DisplayMemberPath="Name"
                      Width="150" Margin="5,0"
                      ToolTip="Фильтр по жанру"/>
        </StackPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить книгу" Command="{Binding AddBookCommand}"
                    Width="120" Margin="0,0,5,0" Padding="5"/>
            <Button Content="Редактировать" Command="{Binding EditBookCommand}"
                    Width="100" Margin="5,0" Padding="5"/>
            <Button Content="Удалить" Command="{Binding DeleteBookCommand}"
                    Width="80" Margin="5,0" Padding="5"/>
            <Button Content="Авторы" Command="{Binding ManageAuthorsCommand}"
                    Width="80" Margin="5,0" Padding="5"/>
            <Button Content="Жанры" Command="{Binding ManageGenresCommand}"
                    Width="80" Margin="5,0" Padding="5"/>
            <Button Content="Обновить" Command="{Binding RefreshCommand}"
                    Width="80" Margin="5,0" Padding="5"/>
        </StackPanel>

        <!-- DataGrid для списка книг -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="LightGray"
                  AlternationCount="2"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.LastName}" Width="*"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="*"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="Auto"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="150"/>
                <DataGridTextColumn Header="Издатель" Binding="{Binding Publisher}" Width="*"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Строка состояния -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Books.Count, StringFormat='Всего книг: {0}'}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>